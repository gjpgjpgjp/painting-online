  <!-- 动作定义 -->
  <action name="penButton">
   <property name="checkable">
    <bool>true</bool>
   </property>
   <property name="icon">
    <iconset theme="document-edit"/>
   </property>
   <property name="text">
    <string>画笔</string>
   </property>
  </action>
  <action name="rectButton">
   <property name="checkable">
    <bool>true</bool>
   </property>
   <property name="text">
    <string>矩形</string>
   </property>
  </action>
  <action name="ellipseButton">
   <property name="checkable">
    <bool>true</bool>
   </property>
   <property name="text">
    <string>椭圆</string>
   </property>
  </action>
  <action name="eraserFullButton">
   <property name="checkable">
    <bool>true</bool>
   </property>
   <property name="text">
    <string>整笔删除</string>
   </property>
  </action>
  <action name="eraserRealTimeButton">
   <property name="checkable">
    <bool>true</bool>
   </property>
   <property name="text">
    <string>实时擦除</string>
   </property>
  </action>
  <action name="colorButton">
