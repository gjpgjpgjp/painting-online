   </property>
  </action>
  <action name="redoButton">
   <property name="text">
    <string>重做</string>
   </property>
   <property name="shortcut">
    <string>Ctrl+Y</string>
   </property>
  </action>
  <action name="clearButton">
   <property name="text">
    <string>清空</string>
   </property>
  </action>
  <action name="actionNewCanvas">
   <property name="text">
    <string>新建画布</string>
   </property>
   <property name="shortcut">
    <string>Ctrl+N</string>
   </property>
  </action>
  <action name="actionOpenCanvas">
   <property name="text">
    <string>打开画布</string>
   </property>
   <property name="shortcut">
    <string>Ctrl+O</string>
   </property>
  </action>
  <action name="actionSaveCanvas">
   <property name="text">
    <string>保存画布</string>
   </property>
   <property name="shortcut">
    <string>Ctrl+S</string>
   </property>
  </action>
  <action name="actionExportPNG">
   <property name="text">
    <string>导出为PNG...</string>
   </property>
  </action>
  <action name="actionExportJPEG">
   <property name="text">
    <string>导出为JPEG...</string>
   </property>
  </action>
  <!-- 新增同步动作 -->
  <action name="syncAction">
   <property name="text">
    <string>同步</string>
   </property>
   <property name="toolTip">
    <string>手动同步房主画布</string>
   </property>
   <property name="shortcut">
    <string>F5</string>
   </property>
  </action>
