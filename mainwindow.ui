<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>900</width>
    <height>600</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>协同绘图</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
    QMainWindow {
        background-color: #f0f0f0;
    }
    QWidget#connectWidget {
        background-color: #ffffff;
        border: 1px solid #d0d0d0;
        border-radius: 8px;
        margin: 20px;
        padding: 15px;
    }
    QToolBar {
        background-color: #e6e6e6;
        border: 1px solid #c0c0c0;
        border-radius: 6px;
        margin: 2px;
        spacing: 3px;
    }
    QToolButton {
        background-color: #f0f0f0;
        border: 1px solid #b0b0b0;
        border-radius: 4px;
        padding: 4px;
        min-width: 30px;
    }
    QToolButton:hover {
        background-color: #ffffff;
        border: 1px solid #808080;
    }
    QToolButton:pressed, QToolButton:checked {
        background-color: #d0d0d0;
        border: 1px solid #505050;
    }
    QLineEdit, QSpinBox, QSlider::groove:horizontal {
        border: 1px solid #b0b0b0;
        border-radius: 3px;
        background-color: #ffffff;
    }
    QLineEdit:focus, QSpinBox:focus {
        border-color: #3399ff;
    }
    QSlider::groove:horizontal {
        height: 4px;
        background: #d0d0d0;
    }
    QSlider::handle:horizontal {
        background: #808080;
        width: 12px;
        margin: -4px 0;
        border-radius: 3px;
    }
    QPushButton {
        background-color: #f0f0f0;
        border: 1px solid #b0b0b0;
        border-radius: 3px;
        padding: 5px 10px;
    }
    QPushButton:hover {
        background-color: #ffffff;
    }
    QPushButton:pressed {
        background-color: #d0d0d0;
    }
    QPushButton#addLayerBtn, QPushButton#deleteLayerBtn {
        min-width: 30px;
        max-width: 30px;
        padding: 2px;
        font-weight: bold;
    }
    QRadioButton {
        spacing: 5px;
    }
    QRadioButton::indicator {
        width: 15px;
        height: 15px;
    }
    QMenuBar {
        background-color: #e0e0e0;
    }
    QListWidget {
        background-color: #ffffff;
        border: 1px solid #b0b0b0;
        border-radius: 3px;
    }
    QListWidget::item {
        padding: 5px;
        border-bottom: 1px solid #e0e0e0;
    }
    QListWidget::item:selected {
        background-color: #3399ff;
        color: white;
    }
    QGroupBox {
        font-weight: bold;
        border: 1px solid #c0c0c0;
        border-radius: 5px;
        margin-top: 10px;
        padding-top: 10px;
    }
    QGroupBox::title {
        subcontrol-origin: margin;
        left: 10px;
        padding: 0 5px;
    }
   </string>
  </property>
