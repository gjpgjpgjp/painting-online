<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>900</width>
    <height>600</height>
   </rect>
  </property>
  <property name="minimumSize">
   <size>
    <width>900</width>
    <height>600</height>
   </size>
  </property>
  <property name="windowTitle">
   <string>同步绘画</string>
  </property>
  <property name="styleSheet">
   <string notr="true">
    /* 全局字体 */
    * {
        font-family: '微软雅黑', 'Segoe UI', sans-serif;
        font-size: 12px;
    }

    /* 主窗口透明背景 */
    QMainWindow {
        background: transparent;
    }

    /* 中央部件透明 */
    QWidget#centralwidget {
        background: transparent;
    }

    /* 自定义标题栏：半透深色玻璃，高度32px */
    QWidget#titleBar {
        background: rgba(30, 40, 50, 0.75);
        border-bottom: 1px solid rgba(255, 255, 255, 0.3);
        border-radius: 12px 12px 0 0;
        min-height: 32px;
        max-height: 32px;
    }
    QLabel#titleLabel {
        color: white;
        font-weight: bold;
        font-size: 13px;
        padding-left: 12px;
    }
    QPushButton#minimizeBtn, QPushButton#maximizeBtn, QPushButton#closeBtn {
        background: rgba(255, 255, 255, 0.2);
        border: none;
        border-radius: 6px;
        min-width: 28px;
        max-width: 28px;
        min-height: 28px;
        max-height: 28px;
        color: white;
        font-weight: bold;
        font-size: 14px;
    }
    QPushButton#minimizeBtn:hover { background: rgba(46, 204, 113, 0.7); }
    QPushButton#maximizeBtn:hover { background: rgba(241, 196, 15, 0.7); }
    QPushButton#closeBtn:hover { background: rgba(231, 76, 60, 0.8); }

    /* 登录面板：半透白 */
    QWidget#connectWidget {
        background-color: rgba(255, 255, 255, 0.7);
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 24px;
    }
    QWidget#connectWidget QLabel,
    QWidget#connectWidget QLineEdit,
    QWidget#connectWidget QRadioButton,
    QWidget#connectWidget QPushButton {
        color: #1e2a36;
    }

    /* 工具栏：浅蓝色半透明 */
    QToolBar {
        background-color: rgba(173, 216, 230, 0.7);
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 20px;
        margin: 12px;
        spacing: 8px;
        padding: 10px;
    }
    QToolBar QLabel,
    QToolBar QComboBox,
    QToolBar QSpinBox,
    QToolBar QCheckBox,
    QToolBar QPushButton {
        color: #2c3e50;
    }

    /* 工具按钮 */
    QToolButton {
        background: rgba(255, 255, 255, 0.8);
        border: 1px solid rgba(255, 255, 255, 0.6);
        border-radius: 12px;
        padding: 8px;
        min-width: 36px;
        min-height: 36px;
        color: #2c3e50;
    }
    QToolButton:hover {
        background: rgba(255, 255, 255, 0.95);
    }
    QToolButton:pressed, QToolButton:checked {
        background: rgba(52, 152, 219, 0.8);
        color: white;
    }

    /* 输入框、微调框 */
    QLineEdit, QSpinBox {
        background-color: rgba(255, 255, 255, 0.85);
        border: 1px solid rgba(255, 255, 255, 0.6);
        border-radius: 10px;
        padding: 6px 10px;
        color: #1e2a36;
    }
    QLineEdit:focus, QSpinBox:focus {
        background-color: rgba(255, 255, 255, 0.95);
        border-color: #3498db;
    }

    /* 滑块 */
    QSlider::groove:horizontal {
        height: 8px;
        background: rgba(255, 255, 255, 0.4);
        border-radius: 4px;
    }
    QSlider::handle:horizontal {
        background: qradialgradient(cx:0.5, cy:0.5, radius:0.8,
                                    stop:0 #3498db, stop:1 #2980b9);
        width: 20px;
        height: 20px;
        margin: -6px 0;
        border-radius: 10px;
        border: 2px solid rgba(255, 255, 255, 0.8);
    }

    /* 普通按钮 */
    QPushButton {
        background: rgba(255, 255, 255, 0.85);
        border: 1px solid rgba(255, 255, 255, 0.6);
        border-radius: 12px;
        padding: 8px 16px;
        color: #2c3e50;
    }
    QPushButton:hover {
        background: rgba(255, 255, 255, 0.95);
    }
    QPushButton:pressed {
        background: rgba(52, 152, 219, 0.8);
        color: white;
    }

    /* 图层按钮 */
    QPushButton#addLayerBtn, QPushButton#deleteLayerBtn {
        min-width: 36px;
        max-width: 36px;
        min-height: 36px;
        max-height: 36px;
        padding: 0;
        font-size: 18px;
        border-radius: 18px;
        background: rgba(255, 255, 255, 0.85);
    }
    QPushButton#addLayerBtn:pressed {
        background: rgba(46, 204, 113, 0.8);
    }
    QPushButton#deleteLayerBtn:pressed {
        background: rgba(231, 76, 60, 0.8);
    }

    /* 单选按钮 */
    QRadioButton {
        color: #2c3e50;
        font-weight: bold;
    }
    QRadioButton::indicator {
        width: 18px;
        height: 18px;
        border-radius: 9px;
        border: 2px solid rgba(255, 255, 255, 0.6);
        background: rgba(255, 255, 255, 0.4);
    }
    QRadioButton::indicator:checked {
        background: qradialgradient(cx:0.5, cy:0.5, radius:0.5,
                                    stop:0 #3498db, stop:0.5 #3498db, stop:1 rgba(255,255,255,0));
    }

    /* 菜单栏 */
    QMenuBar {
        background: rgba(255, 255, 255, 0.85);
        border: none;
        padding: 4px;
    }
    QMenuBar::item {
        color: #2c3e50;
        padding: 6px 12px;
        border-radius: 8px;
    }
    QMenuBar::item:selected {
        background: rgba(52, 152, 219, 0.3);
    }
    QMenu {
        background-color: rgba(255, 255, 255, 0.95);
        border: 1px solid rgba(200, 200, 200, 0.8);
        border-radius: 12px;
    }
    QMenu::item {
        color: #2c3e50;
        padding: 8px 28px;
    }
    QMenu::item:selected {
        background: rgba(52, 152, 219, 0.8);
        color: white;
    }

    /* 图层列表 */
    QListWidget {
        background-color: rgba(255, 255, 255, 0.85);
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 12px;
        padding: 6px;
    }
    QListWidget::item {
        color: #2c3e50;
        padding: 8px 10px;
    }
    QListWidget::item:selected {
        background: rgba(52, 152, 219, 0.8);
        color: white;
    }

    /* 分组框 */
    QGroupBox {
        background-color: rgba(255, 255, 255, 0.75);
        border: 1px solid rgba(255, 255, 255, 0.5);
        border-radius: 16px;
    }
    QGroupBox::title {
        color: #2c3e50;
        background-color: rgba(255, 255, 255, 0.8);
        border-radius: 8px;
    }

    /* 复选框 */
    QCheckBox {
        color: #2c3e50;
    }
    QCheckBox::indicator {
        width: 18px;
        height: 18px;
        border-radius: 5px;
        border: 2px solid rgba(255, 255, 255, 0.6);
        background: rgba(255, 255, 255, 0.4);
    }
    QCheckBox::indicator:checked {
        background: #3498db;
    }

    /* 下拉框 */
    QComboBox {
        background: rgba(255, 255, 255, 0.85);
        border: 1px solid rgba(255, 255, 255, 0.6);
        border-radius: 10px;
        padding: 6px 10px;
        color: #2c3e50;
    }

    /* 画布容器：纯白实心 */
    QWidget#canvasContainer {
        background-color: white;
        border: none;
    }

    /* 标签 */
    QLabel {
        color: #2c3e50;
    }

    /* 滚动条 */
    QScrollBar:vertical {
        background: rgba(255, 255, 255, 0.3);
        width: 12px;
        border-radius: 6px;
    }
    QScrollBar::handle:vertical {
        background: rgba(52, 152, 219, 0.6);
        border-radius: 6px;
    }
   </string>
  </property>
