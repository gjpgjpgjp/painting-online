     <number>2</number>
    </property>
    <property name="toolTip">
     <string>笔刷大小</string>
    </property>
    <property name="maximumWidth">
     <number>100</number>
    </property>
   </widget>
   <widget class="QSpinBox" name="opacitySpinBox">
    <property name="minimum">
     <number>0</number>
    </property>
    <property name="maximum">
     <number>100</number>
    </property>
    <property name="value">
     <number>100</number>
    </property>
    <property name="suffix">
     <string>%</string>
    </property>
    <property name="toolTip">
     <string>透明度</string>
    </property>
   </widget>
   <addaction name="separator"/>

   <!-- 编辑操作 -->
   <addaction name="undoButton"/>
   <addaction name="redoButton"/>
   <addaction name="clearButton"/>
   <addaction name="separator"/>

   <!-- 同步 -->
   <addaction name="syncAction"/>
  </widget>

